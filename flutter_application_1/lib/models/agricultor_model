class Agricultor {
  final String id;
  final String nombre;
  final String email;
  final String? telefono;
  final String? foto;
  final DateTime? fechaRegistro;
  final bool activo;

  Agricultor({
    required this.id,
    required this.nombre,
    required this.email,
    this.telefono,
    this.foto,
    this.fechaRegistro,
    this.activo = true,
  });

  factory Agricultor.fromJson(Map<String, dynamic> json) {
    return Agricultor(
      id: json['id']?.toString() ?? '',
      nombre: json['nombre'] ?? json['name'] ?? '',
      email: json['email'] ?? '',
      telefono: json['telefono'] ?? json['phone'],
      foto: json['foto'] ?? json['photo'],
      fechaRegistro: json['fechaRegistro'] != null 
          ? DateTime.tryParse(json['fechaRegistro'])
          : null,
      activo: json['activo'] ?? true,
    );
  }

  Map<String, dynamic> toJson() {
    return {
      'id': id,
      'nombre': nombre,
      'email': email,
      'telefono': telefono,
      'foto': foto,
      'fechaRegistro': fechaRegistro?.toIso8601String(),
      'activo': activo,
    };
  }

  // Método útil para crear copias con modificaciones
  Agricultor copyWith({
    String? id,
    String? nombre,
    String? email,
    String? telefono,
    String? foto,
    DateTime? fechaRegistro,
    bool? activo,
  }) {
    return Agricultor(
      id: id ?? this.id,
      nombre: nombre ?? this.nombre,
      email: email ?? this.email,
      telefono: telefono ?? this.telefono,
      foto: foto ?? this.foto,
      fechaRegistro: fechaRegistro ?? this.fechaRegistro,
      activo: activo ?? this.activo,
    );
  }
}